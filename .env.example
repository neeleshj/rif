# Copy to .env and adjust. See README "Repository and setup".

# --- API (apps/api) ---
API_PORT=3001
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rif

# Algorithm / validation limits
MAX_GRID_SIZE=1000

# Write queue
QUEUE_MAX_SIZE=100000
BATCH_SIZE=500
BATCH_INTERVAL_MS=100

# Logging
LOG_LEVEL=info
LOG_SAMPLE_RATE=0.001

# --- Web (apps/web) ---
# Server-side only: used by the /api route handlers to reach the backend.
BACKEND_URL=http://localhost:3001
# The web app serves on Next's default port 3000. To change it, set PORT in your
# shell (PORT=4000 npm run dev), not here: Next reads the port before .env loads.
