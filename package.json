{
  "name": "rif",
  "version": "1.0.0",
  "private": true,
  "description": "RIF technical test: mutant detector",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
