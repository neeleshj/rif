    "@rif/shared": "*",
    "dotenv": "^16.6.1",
    "fastify": "^5.1.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
